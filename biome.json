{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noAssignInExpressions": "off"
      },
      "style": {
        "noVar": "warn",
        "useConst": "warn",
        "noUnusedTemplateLiteral": "off",
        "useSingleVarDeclarator": "off",
        "useTemplate": "off"
      },
      "correctness": { "noUndeclaredVariables": "off" },
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "files": {
    "include": ["js/**/*.js", "tests/**/*.js"],
    "ignore": ["functions/**"]
  }
}
